<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    android:padding="30dp">

    <TextView
        android:id="@+id/tvLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MONOGATARI"
        android:textColor="@color/netflix_red"
        android:textSize="28sp"
        android:fontFamily="sans-serif-black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="20dp" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Unlimited stories, manga, and more."
        android:textColor="@color/text_main"
        android:textSize="18sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toBottomOf="@id/tvLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <EditText
        android:id="@+id/etUsername"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:hint="Username"
        android:background="@drawable/bg_input_netflix"
        android:paddingHorizontal="16dp"
        android:textColor="@color/text_main"
        android:textColorHint="@color/text_hint"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        android:layout_marginTop="24dp" />

    <EditText
        android:id="@+id/etEmail"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:hint="Email"
        android:background="@drawable/bg_input_netflix"
        android:paddingHorizontal="16dp"
        android:textColor="@color/text_main"
        android:textColorHint="@color/text_hint"
        app:layout_constraintTop_toBottomOf="@id/etUsername"
        android:layout_marginTop="12dp"
        android:inputType="textEmailAddress" />

    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:hint="Password"
        android:background="@drawable/bg_input_netflix"
        android:paddingHorizontal="16dp"
        android:textColor="@color/text_main"
        android:textColorHint="@color/text_hint"
        android:inputType="textPassword"
        app:layout_constraintTop_toBottomOf="@id/etEmail"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/btnRegister"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Sign Up"
        android:backgroundTint="@color/netflix_red"
        android:textColor="@color/text_main"
        android:textStyle="bold"
        app:cornerRadius="4dp"
        app:layout_constraintTop_toBottomOf="@id/etPassword"
        android:layout_marginTop="24dp" />

    <LinearLayout
        android:id="@+id/llDivider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/btnRegister">

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="@color/input_border" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" OR "
            android:textColor="@color/text_hint"
            android:textSize="12sp"
            android:paddingHorizontal="16dp" />
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="@color/input_border" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGoogle"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Continue with Google"
        android:textColor="@color/text_main"
        android:textAllCaps="false"
        app:strokeColor="@color/input_border"
        app:cornerRadius="4dp"
        app:icon="@drawable/ic_google"
        app:iconGravity="textStart"
        app:iconTint="@android:color/transparent"
        app:iconTintMode="src_atop"
        app:layout_constraintTop_toBottomOf="@id/llDivider"
        android:layout_marginTop="20dp" />

    <TextView
        android:id="@+id/tvGoToLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Already have an account? Sign in"
        android:textColor="@color/text_main"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="20dp" />

</androidx.constraintlayout.widget.ConstraintLayout>