<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    android:padding="30dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Verify OTP"
        android:textColor="@color/text_main"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="40dp" />

    <EditText
        android:id="@+id/etOtpCode"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Enter 6-digit code"
        android:background="@drawable/bg_input_netflix"
        android:paddingHorizontal="16dp"
        android:textColor="@color/text_main"
        android:textColorHint="@color/text_hint"
        android:inputType="number"
        android:gravity="center"
        android:letterSpacing="0.3"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        android:layout_marginTop="40dp" />

    <Button
        android:id="@+id/btnVerify"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Verify"
        android:backgroundTint="@color/netflix_red"
        android:textColor="@color/text_main"
        android:textStyle="bold"
        app:cornerRadius="4dp"
        app:layout_constraintTop_toBottomOf="@id/etOtpCode"
        android:layout_marginTop="24dp" />

    <TextView
        android:id="@+id/tvResend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Didn't receive code? Resend."
        android:textColor="@color/text_main"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnVerify"
        android:layout_marginTop="24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>