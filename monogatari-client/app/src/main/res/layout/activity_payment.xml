<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvPaymentTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MEMBERSHIP"
        android:textAlignment="center"
        android:textColor="@color/text_charcoal"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:letterSpacing="0.2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/tvPaymentSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Join the inner circle of Monogatari"
        android:textAlignment="center"
        android:textColor="@color/vintage_accent"
        android:fontFamily="serif"
        android:fontStyle="italic"
        app:layout_constraintTop_toBottomOf="@id/tvPaymentTitle" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMonthly"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/input_background"
        app:cardCornerRadius="0dp"
        app:strokeColor="@color/vintage_accent"
        app:strokeWidth="1dp"
        android:layout_marginTop="60dp"
        app:layout_constraintTop_toBottomOf="@id/tvPaymentSubtitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MONTHLY PRO"
                android:textColor="@color/text_charcoal"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Full access to AI archives &amp; Premium stories"
                android:textColor="@color/text_charcoal"
                android:alpha="0.7"
                android:textAlignment="center"
                android:fontFamily="serif" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="$9.99"
                android:textColor="@color/vintage_accent"
                android:textSize="32sp"
                android:textStyle="bold"
                android:fontFamily="serif" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="per month"
                android:textColor="@color/vintage_accent"
                android:textSize="12sp"
                android:fontFamily="serif" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPayMonthly"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:text="START SUBSCRIPTION"
                android:fontFamily="serif"
                android:letterSpacing="0.1"
                android:backgroundTint="@color/vintage_accent"
                android:textColor="@color/page_background"
                app:cornerRadius="0dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="Secure payment processed via Stripe"
        android:textAlignment="center"
        android:textColor="@color/text_charcoal"
        android:textSize="12sp"
        android:alpha="0.5"
        android:fontFamily="serif"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>