<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_page"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <TextView
        android:id="@+id/tvChapterNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1"
        android:textColor="@color/text_main"
        android:textSize="20sp"
        android:fontFamily="sans-serif-black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/vDivider"
        android:layout_marginStart="24dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp" />

    <TextView
        android:id="@+id/tvChapterTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Chapter Title"
        android:textColor="@color/text_main"
        android:textSize="16sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintStart_toEndOf="@id/tvChapterNumber"
        app:layout_constraintEnd_toStartOf="@+id/ivPremiumLock"
        app:layout_constraintTop_toTopOf="@id/tvChapterNumber"
        app:layout_constraintBottom_toTopOf="@+id/tvChapterDate"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="16dp" />

    <TextView
        android:id="@+id/tvChapterDate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Nov 24, 2023"
        android:textColor="@color/text_hint"
        android:textSize="12sp"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toStartOf="@id/tvChapterTitle"
        app:layout_constraintEnd_toEndOf="@id/tvChapterTitle"
        app:layout_constraintTop_toBottomOf="@id/tvChapterTitle"
        app:layout_constraintBottom_toBottomOf="@id/tvChapterNumber" />

    <ImageView
        android:id="@+id/ivPremiumLock"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/ic_secure"
        app:tint="@color/netflix_red"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvChapterNumber"
        app:layout_constraintBottom_toBottomOf="@id/tvChapterNumber"
        android:layout_marginEnd="24dp"
        android:visibility="gone" />

    <View
        android:id="@+id/vDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/input_border"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>