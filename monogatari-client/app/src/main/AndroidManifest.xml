<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true"
        android:enableOnBackInvokedCallback="true"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MonogatariApp">

        <activity
            android:name=".ui.view.ReaderActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <activity
            android:name=".ui.view.WelcomeActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.view.MainActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.view.StoryDetailActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.view.GenreFilterActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.view.AuthorActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.view.AiChatActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.view.ExploreActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustPan" />

        <activity
            android:name=".ui.view.OAuth2RedirectActivity"
            android:exported="true">
            <intent-filter android:label="OAuth2 Redirect">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="monogatari"
                    android:host="app.com"
                    android:pathPrefix="/oauth2/redirect" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.view.RegisterActivity" android:exported="false" />
        <activity android:name=".ui.view.LoginActivity" android:exported="false" />
        <activity android:name=".ui.view.VerifyOtpActivity" android:exported="false" android:windowSoftInputMode="stateVisible"/>
        <activity android:name=".ui.view.EmailInputActivity" android:exported="false" />
        <activity android:name=".ui.view.BirthdayActivity" android:exported="false" />
        <activity android:name=".ui.view.ChangePasswordActivity" android:exported="false" />
        <activity android:name=".ui.view.EditProfileActivity" android:exported="false" android:screenOrientation="portrait" android:windowSoftInputMode="adjustPan" />

        <activity
            android:name=".ui.view.SubscriptionActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter android:label="Stripe Integration">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="monogatari" />
            </intent-filter>
        </activity>
    </application>

</manifest>